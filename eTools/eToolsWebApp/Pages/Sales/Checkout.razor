@page "/sales/checkout"
@using eToolsWebApp.Components
@using MudBlazor
<SalesNav />
<h3>Checkout</h3>
@if (State.Cart.Count == 0)
{
    <p>No Items</p>
}
else
{
<table>
   <thead>
   <tr>
       <th></th>
       <th>Qty</th>
       <th>Price</th>
       <th>Total</th>
   </tr>
   </thead>
   <tbody>
   @foreach (var item in State.Cart)
   {
       <tr>
           <td>@item.Description</td>
           <td>@item.Quantity</td>
           <td>$@item.SellingPrice</td>
           <td>$@(item.SellingPrice * item.Quantity)</td>
       </tr>
   }
   </tbody>
</table> 
<div class="d-flex">
    <div class="flex-column">
        <label>Coupon</label>
        <InputText @bind-Value="Coupon"/>
    </div>
    <div class="flex-column">
        <table>
            <tr>
                <th>Subtotal</th>
                <td>@Sale.SubTotal</td>
            </tr>
            <tr>
                <th>Tax</th>
                <td>@Sale.TaxAmount</td>
            </tr>
            <tr>
                <th>@_discount% Discount</th>
                <td>@_discountAmmount</td>
            </tr>
            <tr>
                <th>Total</th>
                <td>@(Sale.SubTotal + Sale.TaxAmount - _discountAmmount)</td>
            </tr>
        </table>
    </div>
</div>
    
<div>
    <MudButton OnClick="ProcessSale">Checkout</MudButton>
</div>
}

